# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# ── Supabase (required) ───────────────────────────────────────────────
# Create a project at https://supabase.com and grab these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Claude access (pick ONE path) ─────────────────────────────────────
# Option A: direct Anthropic API key (simplest)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Option B: route through a local daytrip-proxy (uses your Claude Max
# subscription, no API key). If both are set, the proxy is tried first
# and the API key is the fallback.
# SUKI_PROXY_URL=http://localhost:4242
# SUKI_PROXY_SECRET=some-shared-secret

# ── Admin backdoor (optional) ─────────────────────────────────────────
# Leaves you a hardcoded superuser login that bypasses Supabase auth.
# If ADMIN_EMAIL or ADMIN_PASSWORD is empty, admin login is disabled.
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=change-me
# NEXT_PUBLIC_ADMIN_USER_ID=   # uuid of the admin row in auth.users
# NEXT_PUBLIC_ADMIN_NAME=Your Name
